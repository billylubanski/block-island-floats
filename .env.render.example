# Render manages PORT automatically. Do not set it in the dashboard unless you have a
# non-standard runtime setup.

# Recommended runtime settings for this Flask/Gunicorn service on Render
WEB_CONCURRENCY=2
GUNICORN_TIMEOUT=120
GUNICORN_GRACEFUL_TIMEOUT=30
GUNICORN_LOG_LEVEL=info

# Python runtime behavior
PYTHONDONTWRITEBYTECODE=1
PYTHONUNBUFFERED=1

# Optional: only needed if you run the offline refresh/forecast enrichment tooling
# in a Render job or shell.
NOAA_CDO_TOKEN=
