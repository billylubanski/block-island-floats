# App runtime
FLASK_DEBUG=0

# Cloud platforms usually inject PORT automatically.
# Keep the local default for direct runs and container tests.
PORT=5000

# Gunicorn tuning for cloud web services
WEB_CONCURRENCY=2
GUNICORN_TIMEOUT=120
GUNICORN_GRACEFUL_TIMEOUT=30
GUNICORN_LOG_LEVEL=info

# Python runtime defaults that behave well in containers and cloud logs
PYTHONDONTWRITEBYTECODE=1
PYTHONUNBUFFERED=1

# Optional: enables richer historical weather enrichment during offline refresh jobs.
# The deployed Flask web app does not require this to serve requests.
NOAA_CDO_TOKEN=
